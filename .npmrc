# Always install devDependencies, even when NODE_ENV=production.
#
# This box BUILDS locally (the deployer runs `npm run build` -> tsc, and the
# test/lint gates need vitest/oxlint) — all devDependencies. The services run
# with NODE_ENV=production, and a stray `npm install` in that environment would
# otherwise PRUNE devDeps (removing typescript), which silently breaks every
# deploy's build step and triggered a destructive rollback loop on 2026-06-13.
# Keeping dev deps is always correct here; prod-only pruning is never wanted.
include=dev
