{
  "name": "my-coding-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Local web chat UI on top of the Pi coding-agent SDK",
  "keywords": [
    "ai",
    "chat",
    "coding-assistant",
    "pi-sdk"
  ],
  "license": "MIT",
  "author": "Struis112",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:server & npm run dev:web",
    "dev:supervised": "npm run dev:supervised --workspace=@mca/server",
    "dev:web": "npm run dev --workspace=@mca/web",
    "dev:server": "npm run dev --workspace=@mca/server",
    "build": "npm run build --workspaces",
    "start": "npm run build && npm --workspace=@mca/server run start:prod",
    "start:server": "npm --workspace=@mca/server run start:prod",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace=@mca/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "oxlint apps packages",
    "lint:fix": "oxlint apps packages --fix",
    "lint:deps": "knip",
    "format": "oxfmt apps packages",
    "format:check": "oxfmt apps packages --check",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "setup": "node scripts/setup.mjs",
    "setup:status": "node scripts/setup.mjs --status",
    "service:install": "powershell -ExecutionPolicy Bypass -File scripts/service/install-windows.ps1",
    "service:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/service/uninstall-windows.ps1",
    "deployer:install": "powershell -ExecutionPolicy Bypass -File scripts/service/install-deployer-windows.ps1",
    "deployer:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/service/uninstall-deployer-windows.ps1",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs",
    "pm2:save": "pm2 save",
    "postinstall": "node scripts/postinstall-hint.mjs",
    "prepare": "husky || true",
    "pi": "pi",
    "pi:list": "pi list",
    "pi:update": "pi update",
    "pi:install": "pi install"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "knip": "^5.36.0",
    "lint-staged": "^17.0.6",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "pm2": "^7.0.1",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxfmt",
      "oxlint --fix"
    ],
    "*.{json,md}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
