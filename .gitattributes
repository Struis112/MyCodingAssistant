# Normalize all text files to LF line endings on commit.
# This prevents oxfmt-on-Linux vs oxfmt-on-Windows from disagreeing
# about whitespace in CI.
* text=auto eol=lf

# Binary file types (skip line-ending normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.tgz binary
