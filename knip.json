{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "include": ["files", "dependencies", "unlisted", "binaries"],
  "exclude": [
    "exports",
    "types",
    "nsExports",
    "nsTypes",
    "enumMembers",
    "classMembers",
    "duplicates"
  ],
  "ignoreBinaries": ["powershell", "pi", "playwright"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs"],
      "project": ["scripts/**/*.{mjs,ts}"]
    },
    "apps/server": {
      "entry": ["src/start-prod.ts", "src/scripts/**/*.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["better-sqlite3", "@types/better-sqlite3"]
    },
    "apps/web": {
      "entry": ["e2e/**/*.spec.ts", "src/**/*.test.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"],
      "next": true,
      "ignoreDependencies": ["@tanstack/react-virtual"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"]
    }
  }
}
