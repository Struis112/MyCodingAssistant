{
  "name": "@mca/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:supervised": "tsx watch src/start-dev-supervised.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "node dist/start-prod.js",
    "dev:deployer": "tsx watch src/start-deployer.ts",
    "start:deployer": "node dist/start-deployer.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "pi": "pi"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.15.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  }
}
